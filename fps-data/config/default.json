{
  "_comment": "FPS default configuration. Do NOT edit this file. Use fps-data/config/user.json instead.",
  "version": "0.2.0-dev",

  "pipeline": {
    "max_tokens": 128,
    "language": "en",
    "encoding": "utf-8",
    "stages": {
      "parser":           { "enabled": true },
      "normalizer":       { "enabled": true },
      "duplicate_cleaner":{ "enabled": true },
      "blacklist":        { "enabled": true },
      "whitelist":        { "enabled": true },
      "categorizer":      { "enabled": true },
      "rule_engine":      { "enabled": true },
      "weight_engine":    { "enabled": true },
      "optimizer":        { "enabled": true },
      "exporter":         { "enabled": true }
    }
  },

  "dictionary": {
    "system_dir": "fps-data/dictionaries/system",
    "user_dir":   "fps-data/dictionaries/user",
    "auto_reload": false
  },

  "rules": {
    "dir": "fps-data/rules",
    "auto_reload": false
  },

  "preset": {
    "dir": "fps-data/presets",
    "default": null
  },

  "cache": {
    "enabled": true,
    "max_size": 256,
    "ttl_seconds": 3600
  },

  "backup": {
    "enabled": true,
    "dir": "backup",
    "max_generations": 5
  },

  "logging": {
    "level": "INFO",
    "dir": "logs",
    "filename": "fps.log",
    "max_bytes": 10485760,
    "backup_count": 5,
    "format": "%(asctime)s [%(levelname)s] %(name)s — %(message)s"
  },

  "adapters": {
    "comfyui": {
      "enabled": true,
      "api_version": "v1",
      "host": "127.0.0.1",
      "port": 8188
    }
  },

  "hot_reload": {
    "enabled": false,
    "interval_seconds": 2.0
  }
}
